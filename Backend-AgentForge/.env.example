# ── LLM ──────────────────────────────────────────────────────────────
# Key global de OpenAI (fallback si el workspace no puso la suya).
OPENAI_API_KEY=

# ── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# ── Redis (buffer / debounce) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379
BUFFER_ENABLED=false

# ── GoHighLevel ──────────────────────────────────────────────────────
# MVP usa PIT por sub-cuenta; el OAuth de Marketplace queda para escala.
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=
GHL_WEBHOOK_SECRET=

# ── Google OAuth (conexiones: Calendar, etc.) ────────────────────────
# Crea una app en Google Cloud (OAuth 2.0 Client ID tipo Web), habilita la
# Calendar API y registra el redirect URI de abajo en "Authorized redirect URIs".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/google/callback

# ── Cifrado de credenciales de terceros (tokens OAuth) ───────────────
# Genérala una vez con:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── Frontend (para redirigir de vuelta tras el OAuth) ────────────────
FRONTEND_URL=http://localhost:3000

# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development
